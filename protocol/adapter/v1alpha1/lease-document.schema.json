{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waycloak.io/protocol/adapter/v1alpha1/lease-document.schema.json",
  "title": "Waycloak workload-adapter lease document",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "podUID", "leases"],
  "properties": {
    "apiVersion": { "const": "networking.waycloak.io/v1alpha1" },
    "podUID": { "type": "string", "minLength": 1 },
    "leases": {
      "type": "array",
      "items": { "$ref": "#/$defs/lease" }
    }
  },
  "$defs": {
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "namespace", "name", "state", "gateway", "publicPort", "targetPort", "applicationPort", "applicationPortMode", "protocols", "generation", "issuedAt", "renewAfter", "expiresAt"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "state": { "const": "Active" },
        "gateway": { "type": "string", "minLength": 1 },
        "publicPort": { "$ref": "#/$defs/port" },
        "targetPort": { "$ref": "#/$defs/port" },
        "applicationPort": { "$ref": "#/$defs/port" },
        "applicationPortMode": { "enum": ["Fixed", "ProviderAssigned"] },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["TCP", "UDP"] }
        },
        "generation": { "type": "integer", "minimum": 1 },
        "issuedAt": { "type": "string", "format": "date-time" },
        "renewAfter": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
