{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Amoenus/waycloak/docs/release/manifest.schema.json",
  "type": "object",
  "required": ["schemaVersion", "version", "source", "artifacts", "compatibility", "security"],
  "properties": {
    "schemaVersion": {"const": "1.3.0"},
    "version": {"type": "string", "minLength": 1},
    "source": {
      "type": "object",
      "required": ["repository", "commit", "workflowRun"],
      "properties": {
        "repository": {"type": "string", "format": "uri"},
        "commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "workflowRun": {"type": "string", "format": "uri"}
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["controllerImage", "agentImage", "gatewayManagerImage", "qbittorrentAdapterImage", "bitmagnetAdapterImage", "helmChart", "kclModule"],
      "additionalProperties": {
        "type": "object",
        "required": ["reference", "digest"],
        "properties": {
          "reference": {"type": "string", "pattern": "^.+@sha256:[a-f0-9]{64}$"},
          "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["kubernetes", "cni", "crdStorageVersion", "workloadAdapterProtocol", "workloadAdapterConformanceKit", "referenceAdapters"],
      "properties": {
        "kubernetes": {"type": "array", "items": {"type": "string"}},
        "cni": {"type": "array", "items": {"type": "string"}},
        "crdStorageVersion": {"type": "string"},
        "workloadAdapterProtocol": {"const": "networking.waycloak.io/adapter/v1alpha1"},
        "workloadAdapterConformanceKit": {"const": "workload-adapter-kit-v1alpha1.tar.gz"},
        "referenceAdapters": {
          "type": "object",
          "required": ["qbittorrent", "bitmagnet"],
          "properties": {
            "qbittorrent": {"type": "string", "minLength": 1},
            "bitmagnet": {"type": "string", "minLength": 1}
          },
          "additionalProperties": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "security": {"type": "object"}
  },
  "additionalProperties": false
}
